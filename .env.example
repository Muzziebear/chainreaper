# Chainreaper credentials — copy to .chainreaper/env and fill in.
# NEVER commit the real file; .chainreaper/ is git-ignored.

# LLM backend (S2+ reasoning stages)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Contract source resolution (verified-source fetch)
ETHERSCAN_API_KEY=your-etherscan-key-here

# Per-chain archive RPC endpoints (used for mainnet-fork PoCs).
# Only the chains you actually target need to be set.
ETHEREUM_RPC_URL=https://your-archive-rpc/ethereum
BASE_RPC_URL=https://your-archive-rpc/base
ARBITRUM_RPC_URL=https://your-archive-rpc/arbitrum
OPTIMISM_RPC_URL=https://your-archive-rpc/optimism
POLYGON_RPC_URL=https://your-archive-rpc/polygon
SONIC_RPC_URL=https://your-archive-rpc/sonic
